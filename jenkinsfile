pipeline {

    agent { label 'nitesh' }

    environment {
        AWS_REGION   = "us-east-1"
        ECR_REGISTRY = "public.ecr.aws/u7p8b8p7"
        IMAGE_NAME   = "secure-flask-app"
        IMAGE_TAG    = "${BUILD_NUMBER}"

        GITOPS_PATH  = "gitops-repo/flask-app/flask-chart"

        SCANNER_HOME = tool 'Sonar'
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Nitesh150791/secure-flask-app.git'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('Sonar') {
                    sh """
                    ${SCANNER_HOME}/bin/sonar-scanner \
                      -Dsonar.projectKey=secure-flask-app \
                      -Dsonar.projectName=secure-flask-app \
                      -Dsonar.sources=. \
                      -Dsonar.exclusions=venv/**,**/*.js
                    """
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Python Dependency Scan (pip-audit)') {
            steps {
                sh """
                python3 -m venv audit-env
                . audit-env/bin/activate
                pip install pip-audit
                pip-audit --fail-on high
                """
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                docker build -t ${ECR_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG} .
                """
            }
        }

        stage('Trivy Source Scan') {
            steps {
                sh """
                docker run --rm \
                  -v \$(pwd):/workspace \
                  aquasec/trivy:latest \
                  fs --exit-code 0 --severity LOW,MEDIUM,HIGH /workspace
                """
            }
        }

        stage('Trivy Image Scan') {
            steps {
                sh """
                docker run --rm \
                  -v /var/run/docker.sock:/var/run/docker.sock \
                  aquasec/trivy:latest \
                  image --exit-code 1 --severity HIGH,CRITICAL \
                  ${ECR_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}
                """
            }
        }

        stage('Push to ECR') {
            steps {
                withCredentials([[
                    \$class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-credentials'
                ]]) {
                    sh """
                    aws ecr-public get-login-password --region ${AWS_REGION} | \
                    docker login --username AWS --password-stdin public.ecr.aws

                    docker push ${ECR_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}
                    """
                }
            }
        }

        stage('Update GitOps Repo') {
            steps {
                withCredentials([
                    string(credentialsId: 'github-token', variable: 'GITHUB_TOKEN')
                ]) {
                    sh """
                    rm -rf gitops-repo
                    git clone https://${GITHUB_TOKEN}@github.com/Nitesh150791/gitops-repo.git

                    cd ${GITOPS_PATH}
                    sed -i "s/tag: .*/tag: \\"${IMAGE_TAG}\\"/" values.yaml

                    git config user.name "jenkins"
                    git config user.email "jenkins@example.com"

                    git add values.yaml
                    git commit -m "Update image tag to ${IMAGE_TAG}"
                    git push origin main
                    """
                }
            }
        }
    }

    post {
        success {
            echo "✅ Secure CI/CD pipeline completed successfully!"
        }
        failure {
            echo "❌ Pipeline failed due to quality or security gate."
        }
    }
}
